---
import { site, whatsappHref } from '../content/site';
---
<header class="header">
  <div class="container header-inner">
    <a class="logo" href="/" aria-label={site.name}>
      <img src="/images/logo-guias-negro-web.png" alt={site.name} width="3544" height="915" />
    </a>
    <nav class="nav" aria-label="Principal">
      <a href="/guias/exani-ii#versiones">Versiones</a>
      <a href="/guias/exani-ii#beneficios">Diferenciadores</a>
      <a href="/guias/exani-ii#faq">Preguntas</a>
      <a href="/articulos">Artículos</a>
    </nav>
    <div class="header-actions">
      <button class="theme-toggle" type="button" data-theme-toggle aria-label="Cambiar tema">
        <span class="theme-toggle-icon" data-icon="moon" aria-hidden="true">☾</span>
        <span class="theme-toggle-icon" data-icon="sun" aria-hidden="true">☀</span>
      </button>
      <a class="btn btn-primary" href="/guias/exani-ii#versiones" onclick="trackLandingEvent('click_view_pricing', {location: 'header'})">Comprar</a>
      <a class="btn btn-secondary btn-whatsapp" href={whatsappHref()} onclick="trackLandingEvent('click_whatsapp', {location: 'header'})">WhatsApp</a>
    </div>
  </div>
</header>
