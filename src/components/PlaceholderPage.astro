---
interface Props { title: string; body: string; }
const { title, body } = Astro.props;
---
<section class="placeholder-page">
  <div class="container">
    <span class="eyebrow">En construcción</span>
    <h1>{title}</h1>
    <p class="hero-copy">{body}</p>
    <a class="btn btn-primary" href="/">Volver a la guía</a>
  </div>
</section>
