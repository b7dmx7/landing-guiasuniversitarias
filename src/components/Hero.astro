---
import { product } from '../content/product';

const classicVersion = product.versions.find((version) => version.id === 'clasica')!;
const plusVersion = product.versions.find((version) => version.id === 'plus')!;
const eyebrowPhrases = [
  'No existe una solo versión del examen; necesitas más que eso.',
  'Más de 300 reactivos inéditos'
];
---
<section class="hero">
  <div class="container hero-grid">
    <div>
      <span class="eyebrow">
        <span class="eyebrow-text" data-eyebrow-rotator data-phrases={JSON.stringify(eyebrowPhrases)}>{eyebrowPhrases[0]}</span>
        <button class="theme-toggle theme-toggle-inline" type="button" data-theme-toggle aria-label="Cambiar tema">
          <span class="theme-toggle-icon" data-icon="moon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M20 14.7A7.8 7.8 0 0 1 9.3 4a8.3 8.3 0 1 0 10.7 10.7Z" />
            </svg>
          </span>
          <span class="theme-toggle-icon" data-icon="sun" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2.2M12 19.8V22M4.2 4.2l1.6 1.6M18.2 18.2l1.6 1.6M2 12h2.2M19.8 12H22M4.2 19.8l1.6-1.6M18.2 5.8l1.6-1.6" />
            </svg>
          </span>
        </button>
      </span>
      <h1 class="hero-title">
        <span class="hero-title-line hero-title-line-1"><span>Guía práctica</span></span>
        <span class="hero-title-line hero-title-line-2"><span>para el examen</span></span>
        <span class="hero-title-line hero-title-line-3"><span>más importante</span></span>
        <span class="hero-title-line hero-title-line-4"><span>de tu vida</span></span>
      </h1>
      <p class="hero-copy">{product.heroSubtitle}</p>
      <div class="trust-row">
        {product.stats.map((item) => <span>{item}</span>)}
      </div>
    </div>
    <div class="cover-card">
      <div class="cover-pair" aria-label="Portadas de las guías Clásica y Plus">
        <figure class="cover-preview cover-preview-classic">
          <img src={classicVersion.coverImage} alt={classicVersion.coverAlt} width="2550" height="3300" decoding="async" />
          <figcaption>Clásica</figcaption>
        </figure>
        <figure class="cover-preview cover-preview-plus">
          <img src={plusVersion.coverImage} alt={plusVersion.coverAlt} width="2550" height="3300" decoding="async" />
          <figcaption>Plus</figcaption>
        </figure>
      </div>
      <p class="cover-note">Elige entre Guía Clásica y Guía Plus, ambas en formato físico para estudiar con lápiz, orden y práctica real.</p>
    </div>
  </div>
</section>

<script>
  const eyebrowRotator = document.querySelector('[data-eyebrow-rotator]') as HTMLElement | null;
  const reduceEyebrowMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (eyebrowRotator && !reduceEyebrowMotion) {
    const phrases = JSON.parse(eyebrowRotator.dataset.phrases || '[]') as string[];
    let phraseIndex = 0;

    if (phrases.length > 1) {
      window.setInterval(() => {
        phraseIndex = (phraseIndex + 1) % phrases.length;
        eyebrowRotator.classList.add('is-changing');
        window.setTimeout(() => {
          eyebrowRotator.textContent = phrases[phraseIndex];
          eyebrowRotator.classList.remove('is-changing');
        }, 180);
      }, 3600);
    }
  }
</script>
