---
import { product } from '../content/product';
import { whatsappHref } from '../content/site';
---
<section class="section checkout-section" id="tiempo-entrega">
  <div class="container checkout-layout">
    <div class="section-header checkout-intro">
      <div class="kicker">Compra</div>
      <h1 class="checkout-heading">Tiempo de entrega</h1>
      <p class="lead">Calcula el tiempo que tarda nuestra guía en llegarte con tu código postal. Puedes continuar aquí mismo con tu pedido.</p>
    </div>

    <form class="card form checkout-form" id="checkout-form">
      <div class="checkout-step">
        <span>1</span>
        <div>
          <h2>Entrega</h2>
          <p>Escribe tu código postal para calcular la entrega y completar tu dirección.</p>
        </div>
      </div>

      <div class="form-grid delivery-lookup-grid">
        <div class="field">
          <label for="postalCode">Código postal</label>
          <input id="postalCode" name="postalCode" inputmode="numeric" autocomplete="postal-code" maxlength="5" pattern="[0-9]{5}" placeholder="Ej. 94290" required />
        </div>
        <div class="field delivery-lookup-action">
          <button class="btn btn-secondary" id="postal-lookup-button" type="button">Consultar entrega</button>
        </div>
      </div>
      <p class="form-status" id="checkout-status" aria-live="polite"></p>

      <div class="delivery-estimate-card" id="delivery-estimate-card" hidden aria-live="polite">
        <span class="delivery-estimate-kicker">Fecha estimada</span>
        <strong id="delivery-estimate-window">Calculando entrega...</strong>
        <p id="delivery-estimate-detail">Estamos revisando la mejor ruta disponible para tu código postal.</p>
        <div class="delivery-estimate-meta">
          <span id="delivery-estimate-carrier">Paquetería por definir</span>
        </div>
      </div>

      <div class="form-grid delivery-details-grid" id="delivery-details" hidden>
        <div class="field field-shaded">
          <label for="state">Estado</label>
          <input id="state" name="state" autocomplete="address-level1" readonly required disabled data-delivery-detail />
        </div>
        <div class="field field-shaded">
          <label for="municipality">Municipio o alcaldía</label>
          <input id="municipality" name="municipality" autocomplete="address-level2" readonly required disabled data-delivery-detail />
        </div>
        <div class="field field-shaded">
          <label for="settlement">Colonia o fraccionamiento</label>
          <select id="settlement" name="settlement" required disabled data-delivery-detail>
            <option value="">Primero escribe tu CP</option>
          </select>
        </div>
      </div>

      <div class="form-grid address-details-grid" id="address-details" hidden>
        <div class="field">
          <label for="street">Calle</label>
          <input id="street" name="street" autocomplete="address-line1" required disabled data-address-detail />
        </div>
        <div class="field">
          <label for="externalNumber">Número exterior</label>
          <input id="externalNumber" name="externalNumber" autocomplete="address-line2" required disabled data-address-detail />
        </div>
        <div class="field">
          <label for="internalNumber">Número interior</label>
          <input id="internalNumber" name="internalNumber" autocomplete="address-line3" disabled data-address-detail />
        </div>
        <div class="field full">
          <label for="references">Referencias</label>
          <textarea id="references" name="references" placeholder="Entre calles, color de fachada o detalle útil para la entrega" disabled data-address-detail></textarea>
        </div>
      </div>
      <input type="hidden" name="delivery" value="envio-nacional" />
      <input id="deliveryEstimateWindow" type="hidden" name="deliveryEstimateWindow" />
      <input id="deliveryEstimateCarrier" type="hidden" name="deliveryEstimateCarrier" />

      <div class="checkout-step">
        <span>2</span>
        <div>
          <h2>Guía y datos</h2>
          <p>Con estos datos se prepara la orden y se envía seguimiento por WhatsApp.</p>
        </div>
      </div>

      <div class="form-grid">
        <div class="field">
          <label for="version">Versión</label>
          <select id="version" name="version" required>
            {product.versions.map((version) => <option value={version.id} data-price={version.price}>{version.name} - {version.price}</option>)}
          </select>
        </div>
        <div class="field full payment-method-field">
          <span class="field-label" id="paymentMethodLabel">Método de pago</span>
          <div class="payment-method-options" role="radiogroup" aria-labelledby="paymentMethodLabel">
            <label class="payment-method-option">
              <input type="radio" name="paymentMethod" value="oxxo" checked required />
              <span class="payment-method-symbol payment-method-symbol-oxxo" aria-hidden="true">OXXO</span>
              <span>
                <strong>OXXO Pay</strong>
                <small>Referencia para pagar en tienda</small>
              </span>
            </label>
            <label class="payment-method-option">
              <input type="radio" name="paymentMethod" value="card" required />
              <span class="payment-method-symbol payment-method-symbol-card" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <rect x="3" y="5" width="18" height="14" rx="2.5"></rect>
                  <path d="M3 10h18M7 15h4"></path>
                </svg>
              </span>
              <span>
                <strong>Tarjeta bancaria</strong>
                <small>Crédito o débito</small>
              </span>
            </label>
          </div>
        </div>
        <div class="field">
          <label for="name">Nombre completo</label>
          <input id="name" name="name" autocomplete="name" required />
        </div>
        <div class="field">
          <label for="whatsapp">WhatsApp</label>
          <input id="whatsapp" name="whatsapp" inputmode="tel" autocomplete="tel" required />
        </div>
        <div class="field">
          <label for="email">Correo para recibo</label>
          <input id="email" name="email" type="email" autocomplete="email" required />
        </div>
        <div class="field full checkbox-field">
          <label>
            <input id="terms" name="terms" type="checkbox" required />
            <span>Acepto los <a class="inline-link" href="/terminos">términos</a> y el <a class="inline-link" href="/privacidad">aviso de privacidad</a>.</span>
          </label>
        </div>
      </div>

      <div class="checkout-summary" aria-live="polite">
        <span id="selected-version-label">Guía Clásica</span>
        <strong id="selected-version-price">$419 MXN</strong>
      </div>

      <div class="stripe-payment-panel" id="stripe-payment-panel" hidden>
        <div>
          <h3>Pago seguro</h3>
          <p>Completa el pago aquí mismo. Stripe procesa los datos de tarjeta de forma segura.</p>
        </div>
        <div id="payment-element"></div>
      </div>

      <div class="oxxo-voucher-panel" id="oxxo-voucher-panel" hidden>
        <div>
          <h3>Referencia OXXO</h3>
          <p>Lleva esta referencia a OXXO y paga antes de la fecha de vencimiento.</p>
        </div>
        <dl>
          <div>
            <dt>Referencia</dt>
            <dd id="oxxo-reference">Pendiente</dd>
          </div>
          <div>
            <dt>Vence</dt>
            <dd id="oxxo-expires">Pendiente</dd>
          </div>
        </dl>
        <a class="btn btn-secondary" id="oxxo-voucher-link" href="#" target="_blank" rel="noreferrer" hidden>Ver ficha de pago</a>
      </div>

      <button class="btn btn-primary" id="checkout-submit" type="submit">Preparar pago</button>
      <a class="btn btn-secondary btn-whatsapp" href={whatsappHref('Hola, quiero ayuda para comprar mi guía.')} onclick="trackLandingEvent('click_whatsapp', {location: 'checkout_form'})">Ayuda por WhatsApp</a>
    </form>
  </div>
</section>

<script is:inline src="https://js.stripe.com/v3/"></script>
<script>
  type PostalLookupResponse =
    | {
        ok: true;
        cp: string;
        state: string;
        municipality: string;
        settlements: Array<{ name: string; type?: string | null }>;
      }
    | {
        ok: false;
        error: string;
      };
  type DeliveryEstimateResponse =
    | {
        ok: true;
        carrier: string;
        serviceLabel: string;
        targetCostMxn: number;
        shipsOn: string;
        headline: string;
        detail: string;
        delivery: {
          windowLabel: string;
          minDate: string;
          maxDate: string;
          minBusinessDays: number;
          maxBusinessDays: number;
        };
      }
    | {
        ok: false;
        error: string;
      };

  type CheckoutPayload = Record<string, string>;
  type StripePaymentIntentResponse =
    | {
        ok: true;
        publishableKey: string;
        clientSecret: string;
        paymentIntentId: string;
        amount: number;
        currency: string;
        paymentMethod: 'card' | 'oxxo';
        livemode: boolean;
        version: { id: string; name: string; price: string };
        returnUrl: string;
      }
    | {
        ok: false;
        error?: string;
        message?: string;
        errors?: string[];
      };
  type StripePaymentIntent = {
    id: string;
    status: string;
    next_action?: {
      oxxo_display_details?: {
        number?: string;
        expires_after?: number;
        hosted_voucher_url?: string;
      };
    };
  };
  type StripeConfirmPaymentResult = {
    error?: { message?: string };
    paymentIntent?: StripePaymentIntent;
  };
  type StripePaymentElement = {
    mount: (selector: string) => void;
    unmount: () => void;
  };
  type StripeElements = {
    create: (type: 'payment', options?: Record<string, unknown>) => StripePaymentElement;
  };
  type StripeInstance = {
    elements: (options: { clientSecret: string; appearance?: Record<string, unknown> }) => StripeElements;
    confirmPayment: (options: Record<string, unknown>) => Promise<StripeConfirmPaymentResult>;
    confirmOxxoPayment: (clientSecret: string, options: Record<string, unknown>) => Promise<StripeConfirmPaymentResult>;
  };
  type StripeConstructor = (publishableKey: string) => StripeInstance | null;

  const form = document.querySelector('#checkout-form') as HTMLFormElement | null;
  const postalCodeInput = document.querySelector('#postalCode') as HTMLInputElement | null;
  const postalLookupButton = document.querySelector('#postal-lookup-button') as HTMLButtonElement | null;
  const deliveryDetails = document.querySelector('#delivery-details') as HTMLDivElement | null;
  const deliveryDetailFields = Array.from(document.querySelectorAll('[data-delivery-detail]')) as Array<HTMLInputElement | HTMLSelectElement>;
  const addressDetails = document.querySelector('#address-details') as HTMLDivElement | null;
  const addressDetailFields = Array.from(document.querySelectorAll('[data-address-detail]')) as Array<HTMLInputElement | HTMLTextAreaElement>;
  const deliveryEstimateCard = document.querySelector('#delivery-estimate-card') as HTMLDivElement | null;
  const deliveryEstimateWindow = document.querySelector('#delivery-estimate-window') as HTMLElement | null;
  const deliveryEstimateDetail = document.querySelector('#delivery-estimate-detail') as HTMLParagraphElement | null;
  const deliveryEstimateCarrier = document.querySelector('#delivery-estimate-carrier') as HTMLSpanElement | null;
  const deliveryEstimateWindowInput = document.querySelector('#deliveryEstimateWindow') as HTMLInputElement | null;
  const deliveryEstimateCarrierInput = document.querySelector('#deliveryEstimateCarrier') as HTMLInputElement | null;
  const settlementSelect = document.querySelector('#settlement') as HTMLSelectElement | null;
  const streetInput = document.querySelector('#street') as HTMLInputElement | null;
  const externalNumberInput = document.querySelector('#externalNumber') as HTMLInputElement | null;
  const internalNumberInput = document.querySelector('#internalNumber') as HTMLInputElement | null;
  const referencesTextarea = document.querySelector('#references') as HTMLTextAreaElement | null;
  const stateInput = document.querySelector('#state') as HTMLInputElement | null;
  const municipalityInput = document.querySelector('#municipality') as HTMLInputElement | null;
  const versionSelect = document.querySelector('#version') as HTMLSelectElement | null;
  const paymentMethodField = document.querySelector('.payment-method-field') as HTMLDivElement | null;
  const paymentMethodInputs = Array.from(document.querySelectorAll('input[name="paymentMethod"]')) as HTMLInputElement[];
  const status = document.querySelector('#checkout-status') as HTMLParagraphElement | null;
  const submitButton = document.querySelector('#checkout-submit') as HTMLButtonElement | null;
  const paymentPanel = document.querySelector('#stripe-payment-panel') as HTMLDivElement | null;
  const oxxoVoucherPanel = document.querySelector('#oxxo-voucher-panel') as HTMLDivElement | null;
  const oxxoReference = document.querySelector('#oxxo-reference') as HTMLElement | null;
  const oxxoExpires = document.querySelector('#oxxo-expires') as HTMLElement | null;
  const oxxoVoucherLink = document.querySelector('#oxxo-voucher-link') as HTMLAnchorElement | null;
  const selectedVersionLabel = document.querySelector('#selected-version-label') as HTMLSpanElement | null;
  const selectedVersionPrice = document.querySelector('#selected-version-price') as HTMLElement | null;

  let lookupAbortController: AbortController | null = null;
  let stripe: StripeInstance | null = null;
  let elements: StripeElements | null = null;
  let paymentElement: StripePaymentElement | null = null;
  let paymentReady = false;
  let preparedClientSecret = '';
  let isSubmittingPayment = false;
  let estimateAbortController: AbortController | null = null;

  function setStatus(message: string) {
    if (status) status.textContent = message;
  }

  function focusStreetInput() {
    if (!streetInput || streetInput.disabled) return;
    window.setTimeout(() => {
      streetInput.focus();
    }, 0);
  }

  function focusSettlementSelect() {
    if (!settlementSelect || settlementSelect.disabled) return;
    window.setTimeout(() => {
      settlementSelect.focus();
    }, 0);
  }

  function focusPaymentMethod() {
    const activePaymentMethod = paymentMethodInputs.find((input) => input.checked) || paymentMethodInputs[0];
    if (!activePaymentMethod || !paymentMethodField) return;
    window.setTimeout(() => {
      paymentMethodField.scrollIntoView({ behavior: 'smooth', block: 'center' });
      activePaymentMethod.focus();
    }, 0);
  }

  function getWindowHelpers() {
    return window as Window & {
      Stripe?: StripeConstructor;
      trackLandingEvent?: (name: string, payload?: Record<string, unknown>) => void;
    };
  }

  function serializeForm() {
    const payload: CheckoutPayload = {};
    if (!form) return payload;

    for (const [key, value] of new FormData(form).entries()) {
      if (typeof value === 'string') payload[key] = value;
    }

    return payload;
  }

  function setSubmitState(isLoading: boolean, label?: string) {
    if (!submitButton) return;
    submitButton.disabled = isLoading;
    submitButton.textContent = label || getSubmitLabel();
  }

  function getSubmitLabel() {
    if (paymentReady) return 'Pagar ahora';
    return getSelectedPaymentMethod() === 'oxxo' ? 'Generar referencia OXXO' : 'Preparar pago';
  }

  function getSelectedPaymentMethod() {
    return paymentMethodInputs.find((input) => input.checked)?.value || 'oxxo';
  }

  function clearOxxoVoucher() {
    if (oxxoVoucherPanel) oxxoVoucherPanel.hidden = true;
    if (oxxoReference) oxxoReference.textContent = 'Pendiente';
    if (oxxoExpires) oxxoExpires.textContent = 'Pendiente';
    if (oxxoVoucherLink) {
      oxxoVoucherLink.hidden = true;
      oxxoVoucherLink.href = '#';
    }
  }

  function clearPreparedPayment(message?: string) {
    if (!paymentReady && !paymentElement && !preparedClientSecret && oxxoVoucherPanel?.hidden !== false) return;

    paymentElement?.unmount();
    paymentElement = null;
    elements = null;
    stripe = null;
    paymentReady = false;
    preparedClientSecret = '';
    if (paymentPanel) paymentPanel.hidden = true;
    clearOxxoVoucher();
    setSubmitState(false);
    if (message) setStatus(message);
  }

  function clearDeliveryEstimate() {
    estimateAbortController?.abort();
    estimateAbortController = null;
    if (deliveryEstimateCard) deliveryEstimateCard.hidden = true;
    if (deliveryEstimateWindowInput) deliveryEstimateWindowInput.value = '';
    if (deliveryEstimateCarrierInput) deliveryEstimateCarrierInput.value = '';
  }

  function setDeliveryEstimateLoading() {
    if (deliveryEstimateCard) deliveryEstimateCard.hidden = false;
    renderDeliveryWindow('Calculando entrega...');
    if (deliveryEstimateDetail) deliveryEstimateDetail.textContent = 'Estamos revisando la mejor ruta disponible para tu código postal.';
    if (deliveryEstimateCarrier) deliveryEstimateCarrier.textContent = 'Paquetería por definir';
  }

  function renderDeliveryWindow(windowLabel: string) {
    if (!deliveryEstimateWindow) return;

    deliveryEstimateWindow.innerHTML = '';
    const dateLines = windowLabel.split(/\s+a\s+/).filter(Boolean);
    const lines = dateLines.length > 1 ? dateLines : [windowLabel];

    lines.forEach((line) => {
      const item = document.createElement('span');
      item.className = 'delivery-estimate-date-line';
      item.textContent = line;
      deliveryEstimateWindow.appendChild(item);
    });
  }

  function renderDeliveryEstimate(result: Extract<DeliveryEstimateResponse, { ok: true }>) {
    if (deliveryEstimateCard) deliveryEstimateCard.hidden = false;
    renderDeliveryWindow(result.delivery.windowLabel);
    if (deliveryEstimateDetail) deliveryEstimateDetail.textContent = result.detail;
    if (deliveryEstimateCarrier) deliveryEstimateCarrier.textContent = `${result.carrier} · ${result.serviceLabel}`;
    if (deliveryEstimateWindowInput) deliveryEstimateWindowInput.value = result.delivery.windowLabel;
    if (deliveryEstimateCarrierInput) deliveryEstimateCarrierInput.value = result.carrier;
  }

  async function lookupDeliveryEstimate(cp: string, settlement = '') {
    if (!/^\d{5}$/.test(cp)) {
      clearDeliveryEstimate();
      return false;
    }

    estimateAbortController?.abort();
    estimateAbortController = new AbortController();
    setDeliveryEstimateLoading();

    try {
      const params = new URLSearchParams({ cp });
      if (settlement) params.set('settlement', settlement);
      const response = await fetch(`/api/delivery-estimate?${params.toString()}`, {
        signal: estimateAbortController.signal
      });
      const result = (await response.json()) as DeliveryEstimateResponse;

      if (!response.ok || !result.ok) {
        clearDeliveryEstimate();
        setStatus('No pudimos calcular la entrega para ese código postal todavía.');
        return false;
      }

      renderDeliveryEstimate(result);
      return true;
    } catch (error) {
      if ((error as Error).name === 'AbortError') return false;
      clearDeliveryEstimate();
      setStatus('No se pudo calcular la entrega en este momento.');
      return false;
    }
  }

  function getAppearance() {
    const root = document.documentElement;
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const isDark = root.dataset.theme === 'dark' || (!root.dataset.theme && prefersDark);

    return {
      theme: isDark ? 'night' : 'stripe',
      variables: {
        colorPrimary: '#0057ff',
        borderRadius: '14px',
        fontFamily: 'Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif'
      }
    };
  }

  function buildBillingDetails(payload: CheckoutPayload) {
    return {
      name: payload.name,
      email: payload.email,
      phone: payload.whatsapp,
      address: {
        line1: `${payload.street || ''} ${payload.externalNumber || ''}`.trim(),
        line2: [payload.internalNumber ? `Int. ${payload.internalNumber}` : '', payload.settlement || ''].filter(Boolean).join(', '),
        postal_code: payload.postalCode,
        city: payload.municipality,
        state: payload.state,
        country: 'MX'
      }
    };
  }

  function formatOxxoExpiration(timestamp?: number) {
    if (!timestamp) return 'Pendiente';

    return new Intl.DateTimeFormat('es-MX', {
      dateStyle: 'long',
      timeStyle: 'short'
    }).format(new Date(timestamp * 1000));
  }

  function showOxxoVoucher(paymentIntent?: StripePaymentIntent) {
    const details = paymentIntent?.next_action?.oxxo_display_details;

    if (!details?.number) {
      setStatus('Stripe generó el pago, pero no regresó la referencia OXXO. Revisa el Dashboard de Stripe.');
      return;
    }

    if (oxxoReference) oxxoReference.textContent = details.number;
    if (oxxoExpires) oxxoExpires.textContent = formatOxxoExpiration(details.expires_after);
    if (details.hosted_voucher_url && oxxoVoucherLink) {
      oxxoVoucherLink.href = details.hosted_voucher_url;
      oxxoVoucherLink.hidden = false;
    }
    if (oxxoVoucherPanel) oxxoVoucherPanel.hidden = false;
    setStatus('Referencia OXXO generada. El pedido queda pendiente hasta que Stripe confirme el pago.');
  }

  async function prepareStripePayment(payload: CheckoutPayload) {
    const StripeConstructor = getWindowHelpers().Stripe;

    if (!StripeConstructor) {
      setStatus('Stripe.js no terminó de cargar. Revisa tu conexión e intenta de nuevo.');
      return;
    }

    setSubmitState(true, 'Preparando pago...');

    try {
      const response = await fetch('/api/stripe/payment-intent', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const result = (await response.json()) as StripePaymentIntentResponse;

      if (!result.ok) {
        if (result.error === 'stripe_not_configured') {
          setStatus('Stripe todavía no está configurado. Falta agregar las llaves en Cloudflare.');
        } else {
          setStatus(result.message || 'No se pudo preparar el pago. Revisa los datos e intenta de nuevo.');
        }
        setSubmitState(false, 'Preparar pago');
        return;
      }

      if (!response.ok) {
        setStatus('No se pudo preparar el pago. Intenta de nuevo.');
        setSubmitState(false, 'Preparar pago');
        return;
      }

      clearPreparedPayment();
      stripe = StripeConstructor(result.publishableKey);
      if (!stripe) {
        setStatus('No se pudo inicializar Stripe. Intenta de nuevo.');
        setSubmitState(false, 'Preparar pago');
        return;
      }

      preparedClientSecret = result.clientSecret;

      if (result.paymentMethod === 'oxxo') {
        await confirmOxxoVoucher(payload, result.clientSecret);
        return;
      }

      elements = stripe.elements({
        clientSecret: result.clientSecret,
        appearance: getAppearance()
      });
      paymentElement = elements.create('payment', {
        layout: 'tabs',
        defaultValues: {
          billingDetails: buildBillingDetails(payload)
        }
      });
      paymentElement.mount('#payment-element');
      paymentReady = true;
      if (paymentPanel) paymentPanel.hidden = false;
      setStatus(`Pago listo para ${result.version.name}. Completa los datos de pago y confirma.`);
      setSubmitState(false, `Pagar ${result.version.price}`);
      getWindowHelpers().trackLandingEvent?.('stripe_payment_intent_ready', {
        version: result.version.id,
        amount: result.amount,
        currency: result.currency,
        paymentMethod: result.paymentMethod,
        livemode: result.livemode
      });
    } catch {
      setStatus('No se pudo conectar con Stripe en este momento.');
      setSubmitState(false);
    }
  }

  async function confirmOxxoVoucher(payload: CheckoutPayload, clientSecret: string) {
    if (!stripe) {
      setStatus('No se pudo inicializar Stripe para OXXO. Intenta de nuevo.');
      setSubmitState(false);
      return;
    }

    setSubmitState(true, 'Generando referencia...');

    const billingDetails = buildBillingDetails(payload);

    try {
      const result = await stripe.confirmOxxoPayment(clientSecret, {
        payment_method: {
          billing_details: billingDetails
        }
      });

      if (result.error) {
        setStatus(result.error.message || 'No se pudo generar la referencia OXXO.');
        setSubmitState(false);
        return;
      }

      getWindowHelpers().trackLandingEvent?.('stripe_oxxo_reference_ready', {
        paymentIntentId: result.paymentIntent?.id,
        status: result.paymentIntent?.status
      });

      showOxxoVoucher(result.paymentIntent);
      setSubmitState(false, 'Generar otra referencia');
    } catch {
      setStatus('No se pudo generar la referencia OXXO en este momento.');
      setSubmitState(false);
    }
  }

  async function confirmStripePayment(payload: CheckoutPayload) {
    if (!stripe || !elements || !preparedClientSecret) {
      clearPreparedPayment('Prepara el pago nuevamente.');
      return;
    }

    isSubmittingPayment = true;
    setSubmitState(true, 'Procesando pago...');

    const billingDetails = buildBillingDetails(payload);

    try {
      const result = await stripe.confirmPayment({
        elements,
        confirmParams: {
          return_url: `${window.location.origin}/checkout/success`,
          payment_method_data: {
            billing_details: billingDetails
          },
          shipping: {
            name: payload.name,
            phone: payload.whatsapp,
            address: billingDetails.address
          }
        },
        redirect: 'if_required'
      });

      if (result.error) {
        setStatus(result.error.message || 'No se pudo confirmar el pago.');
        setSubmitState(false);
        isSubmittingPayment = false;
        return;
      }

      getWindowHelpers().trackLandingEvent?.('stripe_payment_confirmed', {
        paymentIntentId: result.paymentIntent?.id,
        status: result.paymentIntent?.status
      });

      if (result.paymentIntent?.status === 'succeeded') {
        window.location.href = `/checkout/success?payment_intent=${encodeURIComponent(result.paymentIntent.id)}`;
        return;
      }

      if (['processing', 'requires_capture'].includes(result.paymentIntent?.status || '')) {
        window.location.href = `/checkout/pending?payment_intent=${encodeURIComponent(result.paymentIntent?.id || '')}`;
        return;
      }

      setStatus('El pago requiere una acción adicional. Revisa el método de pago o intenta con otra tarjeta.');
      setSubmitState(false);
      isSubmittingPayment = false;
    } catch {
      setStatus('No se pudo confirmar el pago en este momento.');
      setSubmitState(false);
      isSubmittingPayment = false;
    }
  }

  function setSettlementOptions(options: Array<{ name: string; type?: string | null }>, placeholder = 'Selecciona colonia') {
    if (!settlementSelect) return;

    settlementSelect.innerHTML = '';
    const firstOption = document.createElement('option');
    firstOption.value = '';
    firstOption.textContent = placeholder;
    settlementSelect.appendChild(firstOption);

    options.forEach((option) => {
      const item = document.createElement('option');
      item.value = option.name;
      item.textContent = option.type ? `${option.name} (${option.type})` : option.name;
      settlementSelect.appendChild(item);
    });

    settlementSelect.disabled = deliveryDetails?.hidden !== false || options.length === 0;
  }

  function setLookupState(isLoading: boolean) {
    if (!postalLookupButton) return;
    postalLookupButton.disabled = isLoading;
    postalLookupButton.textContent = isLoading ? 'Consultando...' : 'Consultar entrega';
  }

  function setDeliveryDetailsVisible(isVisible: boolean) {
    if (deliveryDetails) deliveryDetails.hidden = !isVisible;
    deliveryDetailFields.forEach((field) => {
      field.disabled = !isVisible;
    });
    if (settlementSelect) {
      settlementSelect.disabled = !isVisible || settlementSelect.options.length <= 1;
    }
  }

  function setAddressDetailsVisible(isVisible: boolean) {
    if (addressDetails) addressDetails.hidden = !isVisible;
    addressDetailFields.forEach((field) => {
      field.disabled = !isVisible;
      if (!isVisible) field.value = '';
    });
  }

  function handleAddressEnter(event: KeyboardEvent, nextField?: HTMLInputElement | HTMLTextAreaElement | null) {
    if (event.key !== 'Enter') return;
    event.preventDefault();

    if (nextField && !nextField.disabled) {
      nextField.focus();
      return;
    }

    focusPaymentMethod();
  }

  function resetPostalFields() {
    if (stateInput) stateInput.value = '';
    if (municipalityInput) municipalityInput.value = '';
    setSettlementOptions([], 'Primero escribe tu CP');
    setDeliveryDetailsVisible(false);
    setAddressDetailsVisible(false);
    clearDeliveryEstimate();
  }

  async function lookupPostalCode(cp: string) {
    if (!postalCodeInput || !stateInput || !municipalityInput || !settlementSelect) return false;

    if (!/^\d{5}$/.test(cp)) {
      resetPostalFields();
      setStatus('Escribe un código postal de 5 dígitos.');
      return false;
    }

    lookupAbortController?.abort();
    lookupAbortController = new AbortController();
    setLookupState(true);
    setStatus('Buscando colonias...');

    try {
      const response = await fetch(`/api/postal-code?cp=${encodeURIComponent(cp)}`, {
        signal: lookupAbortController.signal
      });
      const result = (await response.json()) as PostalLookupResponse;

      if (!response.ok || !result.ok) {
        resetPostalFields();
        setStatus('Todavía no encontramos ese código postal. Cuando carguemos el catálogo nacional aparecerá aquí.');
        return false;
      }

      stateInput.value = result.state;
      municipalityInput.value = result.municipality;
      setSettlementOptions(result.settlements);
      setDeliveryDetailsVisible(true);
      setAddressDetailsVisible(false);
      setStatus(`${result.settlements.length} colonia(s) encontradas.`);
      void lookupDeliveryEstimate(cp);
      focusSettlementSelect();
      return true;
    } catch (error) {
      if ((error as Error).name === 'AbortError') return false;
      resetPostalFields();
      setStatus('No se pudo consultar el código postal en este momento.');
      return false;
    } finally {
      setLookupState(false);
    }
  }

  function updateSelectedVersion() {
    if (!versionSelect || !selectedVersionLabel || !selectedVersionPrice) return;
    const option = versionSelect.selectedOptions[0];
    selectedVersionLabel.textContent = option?.textContent?.replace(/\s-\s.*/, '') || 'Guía Clásica';
    selectedVersionPrice.textContent = option?.dataset.price || '$419 MXN';
    if (!paymentReady) setSubmitState(false);
  }

  const params = new URLSearchParams(window.location.search);
  const initialVersion = params.get('version');
  if (versionSelect && initialVersion) {
    const matchingOption = Array.from(versionSelect.options).find((option) => option.value === initialVersion);
    if (matchingOption) versionSelect.value = matchingOption.value;
  }
  updateSelectedVersion();

  postalCodeInput?.addEventListener('input', () => {
    postalCodeInput.value = postalCodeInput.value.replace(/\D/g, '').slice(0, 5);
    resetPostalFields();
    setStatus(postalCodeInput.value.length > 0 && postalCodeInput.value.length < 5 ? 'Escribe un código postal de 5 dígitos.' : '');
  });

  function requestPostalLookup() {
    void lookupPostalCode(postalCodeInput?.value || '');
  }

  postalCodeInput?.addEventListener('keydown', (event) => {
    if (event.key !== 'Enter') return;
    event.preventDefault();
    requestPostalLookup();
  });

  postalLookupButton?.addEventListener('click', requestPostalLookup);

  settlementSelect?.addEventListener('change', () => {
    void lookupDeliveryEstimate(postalCodeInput?.value || '', settlementSelect.value);
    setAddressDetailsVisible(Boolean(settlementSelect.value));
    if (settlementSelect.value) focusStreetInput();
  });

  settlementSelect?.addEventListener('keydown', (event) => {
    if (event.key !== 'Enter' || !settlementSelect.value) return;
    event.preventDefault();
    setAddressDetailsVisible(true);
    focusStreetInput();
  });

  streetInput?.addEventListener('keydown', (event) => {
    handleAddressEnter(event, externalNumberInput);
  });

  externalNumberInput?.addEventListener('keydown', (event) => {
    handleAddressEnter(event, internalNumberInput);
  });

  internalNumberInput?.addEventListener('keydown', (event) => {
    handleAddressEnter(event, referencesTextarea);
  });

  referencesTextarea?.addEventListener('keydown', (event) => {
    if (event.key !== 'Enter' || event.shiftKey) return;
    handleAddressEnter(event);
  });

  versionSelect?.addEventListener('change', updateSelectedVersion);
  paymentMethodInputs.forEach((input) => input.addEventListener('change', () => {
    clearPreparedPayment();
    setSubmitState(false);
  }));

  form?.addEventListener('input', () => {
    if (!isSubmittingPayment) clearPreparedPayment('Actualizaste datos. Prepara el pago nuevamente.');
  });

  form?.addEventListener('change', () => {
    if (!isSubmittingPayment) clearPreparedPayment('Actualizaste datos. Prepara el pago nuevamente.');
  });

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    if (deliveryDetails?.hidden !== false) {
      const didLookupPostalCode = await lookupPostalCode(postalCodeInput?.value || '');
      if (!didLookupPostalCode) return;
    }

    if (!form.reportValidity()) return;

    const payload = serializeForm();
    getWindowHelpers().trackLandingEvent?.('prepare_checkout_form', payload);

    if (paymentReady) {
      await confirmStripePayment(payload);
      return;
    }

    await prepareStripePayment(payload);
  });
</script>
