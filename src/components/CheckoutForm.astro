---
import { product } from '../content/product';
import { whatsappHref } from '../content/site';
---
<section class="section checkout-section" id="tiempo-entrega">
  <div class="container checkout-layout">
    <div class="section-header checkout-intro">
      <div class="kicker">Compra</div>
      <h1 class="checkout-heading">Tiempo de entrega</h1>
      <p class="lead">Calcula el tiempo que tarda nuestra guía en llegarte con tu código postal. Puedes continuar aquí mismo con tu pedido.</p>
    </div>

    <form class="card form checkout-form" id="checkout-form">
      <div class="checkout-step">
        <span>1</span>
        <div>
          <h2>Entrega</h2>
          <p>Escribe tu código postal para calcular la entrega y completar tu dirección.</p>
        </div>
      </div>

      <div class="form-grid">
        <div class="field">
          <label for="postalCode">Código postal</label>
          <input id="postalCode" name="postalCode" inputmode="numeric" autocomplete="postal-code" maxlength="5" pattern="[0-9]{5}" placeholder="Ej. 94290" required />
        </div>
        <div class="field">
          <label for="state">Estado</label>
          <input id="state" name="state" autocomplete="address-level1" readonly required />
        </div>
        <div class="field">
          <label for="municipality">Municipio o alcaldía</label>
          <input id="municipality" name="municipality" autocomplete="address-level2" readonly required />
        </div>
        <div class="field">
          <label for="settlement">Colonia o fraccionamiento</label>
          <select id="settlement" name="settlement" required disabled>
            <option value="">Primero escribe tu CP</option>
          </select>
        </div>
        <div class="field">
          <label for="street">Calle</label>
          <input id="street" name="street" autocomplete="street-address" required />
        </div>
        <div class="field">
          <label for="externalNumber">Número exterior</label>
          <input id="externalNumber" name="externalNumber" autocomplete="address-line2" required />
        </div>
        <div class="field">
          <label for="internalNumber">Número interior</label>
          <input id="internalNumber" name="internalNumber" autocomplete="address-line3" />
        </div>
        <div class="field">
          <label for="delivery">Entrega</label>
          <select id="delivery" name="delivery" required>
            <option value="envio-nacional">Envío nacional gratis</option>
            <option value="entrega-personal">Entrega personal</option>
          </select>
        </div>
        <div class="field full">
          <label for="references">Referencias</label>
          <textarea id="references" name="references" placeholder="Entre calles, color de fachada o detalle útil para la entrega"></textarea>
        </div>
      </div>

      <div class="checkout-step">
        <span>2</span>
        <div>
          <h2>Guía y datos</h2>
          <p>Con estos datos se prepara la orden y se envía seguimiento por WhatsApp.</p>
        </div>
      </div>

      <div class="form-grid">
        <div class="field">
          <label for="version">Versión</label>
          <select id="version" name="version" required>
            {product.versions.map((version) => <option value={version.id} data-price={version.price}>{version.name} - {version.price}</option>)}
          </select>
        </div>
        <div class="field">
          <label for="name">Nombre completo</label>
          <input id="name" name="name" autocomplete="name" required />
        </div>
        <div class="field">
          <label for="whatsapp">WhatsApp</label>
          <input id="whatsapp" name="whatsapp" inputmode="tel" autocomplete="tel" required />
        </div>
        <div class="field">
          <label for="email">Correo para recibo</label>
          <input id="email" name="email" type="email" autocomplete="email" required />
        </div>
        <div class="field full checkbox-field">
          <label>
            <input id="terms" name="terms" type="checkbox" required />
            <span>Acepto los <a class="inline-link" href="/terminos">términos</a> y el <a class="inline-link" href="/privacidad">aviso de privacidad</a>.</span>
          </label>
        </div>
      </div>

      <div class="checkout-summary" aria-live="polite">
        <span id="selected-version-label">Guía Clásica</span>
        <strong id="selected-version-price">$419 MXN</strong>
      </div>

      <div class="stripe-payment-panel" id="stripe-payment-panel" hidden>
        <div>
          <h3>Pago seguro</h3>
          <p>Completa el pago aquí mismo. Stripe procesa los datos de tarjeta de forma segura.</p>
        </div>
        <div id="payment-element"></div>
      </div>

      <button class="btn btn-primary" id="checkout-submit" type="submit">Preparar pago</button>
      <a class="btn btn-secondary btn-whatsapp" href={whatsappHref('Hola, quiero ayuda para comprar mi guía.')} onclick="trackLandingEvent('click_whatsapp', {location: 'checkout_form'})">Ayuda por WhatsApp</a>
      <p class="form-status" id="checkout-status" aria-live="polite"></p>
    </form>
  </div>
</section>

<script is:inline src="https://js.stripe.com/v3/"></script>
<script>
  type PostalLookupResponse =
    | {
        ok: true;
        cp: string;
        state: string;
        municipality: string;
        settlements: Array<{ name: string; type?: string | null }>;
      }
    | {
        ok: false;
        error: string;
      };

  type CheckoutPayload = Record<string, string>;
  type StripePaymentIntentResponse =
    | {
        ok: true;
        publishableKey: string;
        clientSecret: string;
        paymentIntentId: string;
        amount: number;
        currency: string;
        version: { id: string; name: string; price: string };
        returnUrl: string;
      }
    | {
        ok: false;
        error?: string;
        message?: string;
        errors?: string[];
      };
  type StripePaymentIntent = { id: string; status: string };
  type StripeConfirmPaymentResult = {
    error?: { message?: string };
    paymentIntent?: StripePaymentIntent;
  };
  type StripePaymentElement = {
    mount: (selector: string) => void;
    unmount: () => void;
  };
  type StripeElements = {
    create: (type: 'payment', options?: Record<string, unknown>) => StripePaymentElement;
  };
  type StripeInstance = {
    elements: (options: { clientSecret: string; appearance?: Record<string, unknown> }) => StripeElements;
    confirmPayment: (options: Record<string, unknown>) => Promise<StripeConfirmPaymentResult>;
  };
  type StripeConstructor = (publishableKey: string) => StripeInstance | null;

  const form = document.querySelector('#checkout-form') as HTMLFormElement | null;
  const postalCodeInput = document.querySelector('#postalCode') as HTMLInputElement | null;
  const settlementSelect = document.querySelector('#settlement') as HTMLSelectElement | null;
  const stateInput = document.querySelector('#state') as HTMLInputElement | null;
  const municipalityInput = document.querySelector('#municipality') as HTMLInputElement | null;
  const versionSelect = document.querySelector('#version') as HTMLSelectElement | null;
  const status = document.querySelector('#checkout-status') as HTMLParagraphElement | null;
  const submitButton = document.querySelector('#checkout-submit') as HTMLButtonElement | null;
  const paymentPanel = document.querySelector('#stripe-payment-panel') as HTMLDivElement | null;
  const selectedVersionLabel = document.querySelector('#selected-version-label') as HTMLSpanElement | null;
  const selectedVersionPrice = document.querySelector('#selected-version-price') as HTMLElement | null;

  let lookupAbortController: AbortController | null = null;
  let stripe: StripeInstance | null = null;
  let elements: StripeElements | null = null;
  let paymentElement: StripePaymentElement | null = null;
  let paymentReady = false;
  let isSubmittingPayment = false;

  function setStatus(message: string) {
    if (status) status.textContent = message;
  }

  function getWindowHelpers() {
    return window as Window & {
      Stripe?: StripeConstructor;
      trackLandingEvent?: (name: string, payload?: Record<string, unknown>) => void;
    };
  }

  function serializeForm() {
    const payload: CheckoutPayload = {};
    if (!form) return payload;

    for (const [key, value] of new FormData(form).entries()) {
      if (typeof value === 'string') payload[key] = value;
    }

    return payload;
  }

  function setSubmitState(isLoading: boolean, label?: string) {
    if (!submitButton) return;
    submitButton.disabled = isLoading;
    submitButton.textContent = label || (paymentReady ? 'Pagar ahora' : 'Preparar pago');
  }

  function clearPreparedPayment(message?: string) {
    if (!paymentReady && !paymentElement) return;

    paymentElement?.unmount();
    paymentElement = null;
    elements = null;
    stripe = null;
    paymentReady = false;
    if (paymentPanel) paymentPanel.hidden = true;
    setSubmitState(false);
    if (message) setStatus(message);
  }

  function getAppearance() {
    const root = document.documentElement;
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const isDark = root.dataset.theme === 'dark' || (!root.dataset.theme && prefersDark);

    return {
      theme: isDark ? 'night' : 'stripe',
      variables: {
        colorPrimary: '#0057ff',
        borderRadius: '14px',
        fontFamily: 'Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif'
      }
    };
  }

  function buildBillingDetails(payload: CheckoutPayload) {
    return {
      name: payload.name,
      email: payload.email,
      phone: payload.whatsapp,
      address: {
        line1: `${payload.street || ''} ${payload.externalNumber || ''}`.trim(),
        line2: [payload.internalNumber ? `Int. ${payload.internalNumber}` : '', payload.settlement || ''].filter(Boolean).join(', '),
        postal_code: payload.postalCode,
        city: payload.municipality,
        state: payload.state,
        country: 'MX'
      }
    };
  }

  async function prepareStripePayment(payload: CheckoutPayload) {
    const StripeConstructor = getWindowHelpers().Stripe;

    if (!StripeConstructor) {
      setStatus('Stripe.js no terminó de cargar. Revisa tu conexión e intenta de nuevo.');
      return;
    }

    setSubmitState(true, 'Preparando pago...');

    try {
      const response = await fetch('/api/stripe/payment-intent', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const result = (await response.json()) as StripePaymentIntentResponse;

      if (!result.ok) {
        if (result.error === 'stripe_not_configured') {
          setStatus('Stripe todavía no está configurado. Falta agregar las llaves en Cloudflare.');
        } else {
          setStatus(result.message || 'No se pudo preparar el pago. Revisa los datos e intenta de nuevo.');
        }
        setSubmitState(false, 'Preparar pago');
        return;
      }

      if (!response.ok) {
        setStatus('No se pudo preparar el pago. Intenta de nuevo.');
        setSubmitState(false, 'Preparar pago');
        return;
      }

      clearPreparedPayment();
      stripe = StripeConstructor(result.publishableKey);
      if (!stripe) {
        setStatus('No se pudo inicializar Stripe. Intenta de nuevo.');
        setSubmitState(false, 'Preparar pago');
        return;
      }

      elements = stripe.elements({
        clientSecret: result.clientSecret,
        appearance: getAppearance()
      });
      paymentElement = elements.create('payment', {
        layout: 'tabs',
        defaultValues: {
          billingDetails: buildBillingDetails(payload)
        }
      });
      paymentElement.mount('#payment-element');
      paymentReady = true;
      if (paymentPanel) paymentPanel.hidden = false;
      setStatus(`Pago listo para ${result.version.name}. Completa los datos de pago y confirma.`);
      setSubmitState(false, `Pagar ${result.version.price}`);
      getWindowHelpers().trackLandingEvent?.('stripe_payment_intent_ready', {
        version: result.version.id,
        amount: result.amount,
        currency: result.currency
      });
    } catch {
      setStatus('No se pudo conectar con Stripe en este momento.');
      setSubmitState(false, 'Preparar pago');
    }
  }

  async function confirmStripePayment(payload: CheckoutPayload) {
    if (!stripe || !elements) {
      clearPreparedPayment('Prepara el pago nuevamente.');
      return;
    }

    isSubmittingPayment = true;
    setSubmitState(true, 'Procesando pago...');

    const billingDetails = buildBillingDetails(payload);

    try {
      const result = await stripe.confirmPayment({
        elements,
        confirmParams: {
          return_url: `${window.location.origin}/checkout/success`,
          payment_method_data: {
            billing_details: billingDetails
          },
          shipping: {
            name: payload.name,
            phone: payload.whatsapp,
            address: billingDetails.address
          }
        },
        redirect: 'if_required'
      });

      if (result.error) {
        setStatus(result.error.message || 'No se pudo confirmar el pago.');
        setSubmitState(false);
        isSubmittingPayment = false;
        return;
      }

      getWindowHelpers().trackLandingEvent?.('stripe_payment_confirmed', {
        paymentIntentId: result.paymentIntent?.id,
        status: result.paymentIntent?.status
      });

      if (result.paymentIntent?.status === 'succeeded') {
        window.location.href = `/checkout/success?payment_intent=${encodeURIComponent(result.paymentIntent.id)}`;
        return;
      }

      if (['processing', 'requires_capture'].includes(result.paymentIntent?.status || '')) {
        window.location.href = `/checkout/pending?payment_intent=${encodeURIComponent(result.paymentIntent?.id || '')}`;
        return;
      }

      setStatus('El pago requiere una acción adicional. Revisa el método de pago o intenta con otra tarjeta.');
      setSubmitState(false);
      isSubmittingPayment = false;
    } catch {
      setStatus('No se pudo confirmar el pago en este momento.');
      setSubmitState(false);
      isSubmittingPayment = false;
    }
  }

  function setSettlementOptions(options: Array<{ name: string; type?: string | null }>, placeholder = 'Selecciona colonia') {
    if (!settlementSelect) return;

    settlementSelect.innerHTML = '';
    const firstOption = document.createElement('option');
    firstOption.value = '';
    firstOption.textContent = placeholder;
    settlementSelect.appendChild(firstOption);

    options.forEach((option) => {
      const item = document.createElement('option');
      item.value = option.name;
      item.textContent = option.type ? `${option.name} (${option.type})` : option.name;
      settlementSelect.appendChild(item);
    });

    settlementSelect.disabled = options.length === 0;
  }

  function resetPostalFields() {
    if (stateInput) stateInput.value = '';
    if (municipalityInput) municipalityInput.value = '';
    setSettlementOptions([], 'Primero escribe tu CP');
  }

  async function lookupPostalCode(cp: string) {
    if (!postalCodeInput || !stateInput || !municipalityInput || !settlementSelect) return;

    if (!/^\d{5}$/.test(cp)) {
      resetPostalFields();
      setStatus('');
      return;
    }

    lookupAbortController?.abort();
    lookupAbortController = new AbortController();
    setStatus('Buscando colonias...');

    try {
      const response = await fetch(`/api/postal-code?cp=${encodeURIComponent(cp)}`, {
        signal: lookupAbortController.signal
      });
      const result = (await response.json()) as PostalLookupResponse;

      if (!response.ok || !result.ok) {
        resetPostalFields();
        setStatus('Todavía no encontramos ese código postal. Cuando carguemos el catálogo nacional aparecerá aquí.');
        return;
      }

      stateInput.value = result.state;
      municipalityInput.value = result.municipality;
      setSettlementOptions(result.settlements);
      setStatus(`${result.settlements.length} colonia(s) encontradas.`);
    } catch (error) {
      if ((error as Error).name === 'AbortError') return;
      resetPostalFields();
      setStatus('No se pudo consultar el código postal en este momento.');
    }
  }

  function updateSelectedVersion() {
    if (!versionSelect || !selectedVersionLabel || !selectedVersionPrice) return;
    const option = versionSelect.selectedOptions[0];
    selectedVersionLabel.textContent = option?.textContent?.replace(/\s-\s.*/, '') || 'Guía Clásica';
    selectedVersionPrice.textContent = option?.dataset.price || '$419 MXN';
    if (!paymentReady) setSubmitState(false, 'Preparar pago');
  }

  const params = new URLSearchParams(window.location.search);
  const initialVersion = params.get('version');
  if (versionSelect && initialVersion) {
    const matchingOption = Array.from(versionSelect.options).find((option) => option.value === initialVersion);
    if (matchingOption) versionSelect.value = matchingOption.value;
  }
  updateSelectedVersion();

  postalCodeInput?.addEventListener('input', () => {
    postalCodeInput.value = postalCodeInput.value.replace(/\D/g, '').slice(0, 5);
    window.setTimeout(() => lookupPostalCode(postalCodeInput.value), 160);
  });

  versionSelect?.addEventListener('change', updateSelectedVersion);

  form?.addEventListener('input', () => {
    if (!isSubmittingPayment) clearPreparedPayment('Actualizaste datos. Prepara el pago nuevamente.');
  });

  form?.addEventListener('change', () => {
    if (!isSubmittingPayment) clearPreparedPayment('Actualizaste datos. Prepara el pago nuevamente.');
  });

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!form.reportValidity()) return;

    const payload = serializeForm();
    getWindowHelpers().trackLandingEvent?.('prepare_checkout_form', payload);

    if (paymentReady) {
      await confirmStripePayment(payload);
      return;
    }

    await prepareStripePayment(payload);
  });
</script>
