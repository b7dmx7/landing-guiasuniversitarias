---
import { product } from '../content/product';
---
<section id="beneficios" class="section">
  <div class="container">
    <div class="section-header">
      <div class="kicker">Diferenciadores</div>
      <h2>Hecha para estudiar, no para aparentar.</h2>
      <p class="lead">El valor no está solo en la cantidad de ejercicios, sino en el orden, el formato físico y la explicación posterior.</p>
    </div>
    <div class="benefit-grid">
      {product.benefits.map((benefit) => (
        <article class="card benefit-card">
          <h3>{benefit.title}</h3>
          <p>{benefit.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
